# Example environment variables for local development
# Copy this file to .env and modify values as needed
# IMPORTANT: Never commit .env to version control (already ignored by .gitignore)

NODE_ENV=development
PORT=3000

# PostgreSQL configuration
# POSTGRES_PORT is the HOST port mapped to container port 5432.
# If you change POSTGRES_PORT, you MUST also update the port in DATABASE_URL below.
POSTGRES_DB=ledger_mx_dev
POSTGRES_USER=postgres
# Dev-only default; consider changing POSTGRES_PASSWORD for local preference.
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Database connection URL (matches default Postgres values above)
# If POSTGRES_PORT is changed, update the port in this URL accordingly.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ledger_mx_dev

# JWT secret for authentication (replace with a secure value for local development)
JWT_SECRET=replace-with-a-local-development-secret

# Frontend (apps/web)
# VITE_ variables are exposed to the browser via Vite.
VITE_API_BASE_URL=http://localhost:3000

# CORS origin for the API server (allows the Vite dev server to send credentials)
CORS_ORIGIN=http://localhost:5173
