{
  "name": "@ledger-mx/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "drizzle:generate": "drizzle-kit generate:pg --config ./drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "drizzle:push": "drizzle-kit push:pg --config ./drizzle.config.ts",
    "seed:demo": "tsx src/seeds/cli.ts demo",
    "seed:personal": "tsx src/seeds/cli.ts personal",
    "seed:reset": "SEED_ALLOW_RESET=true tsx src/seeds/cli.ts reset",
    "seed:verify": "tsx src/seeds/cli.ts verify"
  },
  "dependencies": {
    "@ledger-mx/domain": "workspace:*",
    "drizzle-orm": "^0.30.4",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.14",
    "@types/pg": "^8.11.0",
    "dotenv": "^16.4.5",
    "testcontainers": "^10.14.0",
    "@testcontainers/postgresql": "^10.14.0",
    "@types/node": "^22.10.0",
    "vitest": "^2.1.8"
  }
}
